{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",

    "outDir": "./dist",
    "rootDir": "./src",

    "strict": true,
    "strictNullChecks": true,

    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    "types": ["node"]
  },

  "include": ["src"]
}